---
import BaseLayout from '../layouts/BaseLayout.astro';

const logos = ["Northstar People", "Cobalt Works", "OpenGrid", "Project House"];

const stats = [
	{
		value: "68%",
		title: "of people teams say feedback arrives too late to improve outcomes.",
		body: "Managers want better conversations, but annual cycles make performance feel like admin instead of coaching.",
	},
	{
		value: "54%",
		title: "of managers struggle to connect individual goals to company priorities.",
		body: "When objectives live in separate documents, alignment becomes guesswork across teams and departments.",
	},
	{
		value: "43%",
		title: "of HR leaders lack confidence in their performance data.",
		body: "People teams need a clear view of check-ins, goals, reviews, and development progress in one place.",
	},
];

const featureRows = [
	{
		label: "Meeting templates",
		title: "Give managers the structure to run better 1:1s.",
		body: "shresorigins gives every manager agenda templates, smart prompts, reminders, and a shared notes space so frequent coaching becomes part of the weekly rhythm.",
		type: "meetings",
	},
	{
		label: "Goal-setting",
		title: "Make goals easier to create, align, and discuss.",
		body: "Teams can draft practical OKRs, connect them to company priorities, and keep progress visible without turning goal-setting into a spreadsheet project.",
		type: "goals",
	},
	{
		label: "In-depth reporting",
		title: "See the context behind performance and engagement.",
		body: "HR leaders can understand whether conversations are happening, where teams need support, and how reviews connect to growth without chasing manual updates.",
		type: "reporting",
	},
];

const benefits = [
	["Automated meeting reminders", "Keep 1:1s, check-ins, and review conversations moving without manual nudges."],
	["Continuous feedback", "Capture useful feedback in the moment so wins and coaching points do not disappear."],
	["Coaching and mentoring", "Create development paths that help employees build skills and connect with leaders."],
	["Shared OKR goals", "Keep teams aligned around priorities, ownership, progress, and measurable outcomes."],
	["Review cycles", "Run lightweight reviews that feel connected to everyday work, not detached from it."],
	["People analytics", "Use clear reporting to understand trends in performance, engagement, and manager follow-through."],
];

const stories = [
	{
		quote: "We completed our review cycle with every team participating because the process finally felt simple.",
		name: "Caroline Ward",
		title: "Chief People Officer",
		company: "Northstar People",
		tone: "mint",
	},
	{
		quote: "shresorigins became our shared home for 1:1s, goals, feedback, and development conversations.",
		name: "Niamh Kelly",
		title: "Head of Culture",
		company: "Cobalt Works",
		tone: "peach",
	},
	{
		quote: "Managers are more consistent, employees know what matters, and HR has the visibility we were missing.",
		name: "Keith Morgan",
		title: "CEO",
		company: "OpenGrid",
		tone: "lemon",
	},
];

const workCards = [
	["Engagement", "Streamline communication with feedback, check-ins, and lightweight insight into team sentiment."],
	["Management", "Equip managers with practical goal-setting, 1:1s, and coaching workflows they can use every week."],
	["Growth & Development", "Connect career conversations to business priorities so people can grow with purpose."],
];

const footerGroups = [
	["How it works", ["Our Platform", "Engagement", "Performance Management", "Growth & Development", "Pricing & Plans"]],
	["Who benefits", ["Managers", "HR Teams", "Companies", "Partners"]],
	["Why us", ["Why shresorigins", "About Us", "Comparisons", "Customer Stories", "Press"]],
	["Resources", ["Knowledge Centre", "ROI Calculator", "Help Centre", "Contact Us"]],
];

const schema = {
	"@context": "https://schema.org",
	"@type": "SoftwareApplication",
	name: "shresorigins",
	applicationCategory: "BusinessApplication",
	description: "shresorigins is a performance management platform for goals, feedback, reviews, and employee development.",
	offers: {
		"@type": "Offer",
		price: "0",
		priceCurrency: "USD",
	},
};
---

<BaseLayout
	title="shresorigins Performance Management"
	description="shresorigins helps growing teams replace outdated performance reviews with connected goals, feedback, reviews, and development conversations."
	ogImageAlt="shresorigins performance management dashboard"
	hideChrome
>
	<header class="site-nav" data-site-header>
		<div class="nav-shell">
			<a class="logo" href="#main" aria-label="shresorigins home">
				<span class="logo-mark" aria-hidden="true"><span></span></span>
				<span>shresorigins</span>
			</a>

			<button class="menu-button" type="button" aria-expanded="false" aria-controls="site-menu" data-nav-toggle>
				<span class="sr-only">Open navigation</span>
				<span></span>
				<span></span>
				<span></span>
			</button>

			<nav class="nav-links" id="site-menu" data-nav-menu aria-label="Primary navigation">
				<a href="#how-it-works">How it works</a>
				<a href="#benefits">Who it benefits</a>
				<a href="#why-us">Why us</a>
				<a href="#resources">Resources</a>
				<a href="#pricing">Pricing</a>
			</nav>

			<div class="nav-actions">
				<a href="#footer">Log in</a>
				<a class="pill-button pill-outline" href="#demo">Book a demo</a>
			</div>
		</div>
	</header>

	<main id="main">
		<section class="hero">
			<div class="hero-art" aria-hidden="true">
				<span class="paper paper-lavender"></span>
				<span class="paper paper-mint"></span>
				<span class="paper paper-coral"></span>
				<span class="paper paper-blue"></span>
				<span class="dash dash-one"></span>
				<span class="dash dash-two"></span>
			</div>

			<div class="hero-shell">
				<div class="hero-copy">
					<h1>Performance management made human.</h1>
					<p>
						Replace outdated reviews with one connected system for goals, feedback, coaching, and growth. shresorigins is built for growing teams that want performance to feel clear, fair, and useful.
					</p>
					<a class="pill-button pill-light" href="#demo">Book a demo</a>
				</div>

				<div class="hero-dashboard" aria-label="shresorigins dashboard preview">
					<div class="mini-card goal-card">
						<span>Active goals for 2026</span>
						<div class="donut" aria-hidden="true"></div>
						<strong>14 Goals</strong>
						<ul>
							<li><b>74%</b> on target</li>
							<li><b>21%</b> progressing</li>
							<li><b>5%</b> at risk</li>
						</ul>
					</div>
					<div class="mini-card focus-card">
						<span>Focus areas</span>
						<div>
							<p>We care.</p>
							<small>Build a healthier culture.</small>
						</div>
						<div>
							<p>Drive growth.</p>
							<small>Expand manager impact.</small>
						</div>
					</div>
					<div class="mini-card deadline-card">
						<div class="card-tabs">
							<span>Upcoming deadlines</span>
							<b>New feed</b>
						</div>
						<p><span>1:1 meeting with Camille</span><b>Today</b></p>
						<p><span>Submit review notes</span><b>Due in 2 days</b></p>
						<p><span>Update growth plan</span><b>Due in 4 days</b></p>
					</div>
				</div>

				<div class="trusted">
					<p>Trusted by HR & People Ops teams</p>
					<div>
						{logos.map((logo) => <span>{logo}</span>)}
					</div>
				</div>
			</div>
		</section>

		<section class="manager-section">
			<div class="section-shell manager-grid">
				<div class="section-heading">
					<p class="eyebrow">For managers</p>
					<h2>Performance management is shared work, but managers need better tools to support it.</h2>
					<a class="text-cta" href="#how-it-works">How we help managers</a>
				</div>
				<aside class="pull-quote">
					<p>"shresorigins gives our managers clarity on what each person is working toward and how progress will be discussed."</p>
					<div>
						<span class="avatar avatar-a"></span>
						<div>
							<strong>Nicole Byrne</strong>
							<span>Chief People Officer, Project House</span>
						</div>
					</div>
				</aside>
			</div>
			<div class="section-shell stats-grid">
				{stats.map((stat) => (
					<article>
						<strong>{stat.value}</strong>
						<h3>{stat.title}</h3>
						<p>{stat.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="support-band" id="why-us">
			<div class="section-shell support-grid">
				<div>
					<p class="eyebrow">Support</p>
					<h2>The first performance platform managers actually enjoy using.</h2>
				</div>
				<div class="support-actions">
					<span>Rated highly for support by growing teams</span>
					<a class="pill-button pill-dark" href="#demo">Book a demo</a>
				</div>
			</div>
		</section>

		<section class="features">
			<div class="section-shell feature-stack">
				{featureRows.map((feature, index) => (
					<article class:list={["feature-row", index % 2 === 1 && "is-reversed"]}>
						<div class="feature-copy">
							<p class="eyebrow">{feature.label}</p>
							<h2>{feature.title}</h2>
							<p>{feature.body}</p>
						</div>
						<div class:list={["feature-visual", `visual-${feature.type}`]} aria-label={`${feature.label} product preview`}>
							{feature.type === "meetings" && (
								<div class="meeting-preview">
									<div class="preview-sidebar"></div>
									<div class="preview-body">
										<span>1:1 agenda</span>
										<h3>Weekly manager check-in</h3>
										<p>Wins, blockers, growth goals, feedback, next steps.</p>
										<ul>
											<li>Celebrate recent progress</li>
											<li>Review goal confidence</li>
											<li>Agree one coaching action</li>
										</ul>
									</div>
								</div>
							)}
							{feature.type === "goals" && (
								<div class="goal-preview">
									<div class="goal-line"><span style="width: 82%"></span></div>
									<div class="goal-line"><span style="width: 64%"></span></div>
									<div class="goal-line"><span style="width: 46%"></span></div>
									<div class="okr-card">
										<span>Company priority</span>
										<strong>Improve customer onboarding</strong>
										<p>4 aligned team goals</p>
									</div>
								</div>
							)}
							{feature.type === "reporting" && (
								<div class="report-preview">
									<div class="bar-chart">
										<span style="height: 52%"></span>
										<span style="height: 76%"></span>
										<span style="height: 64%"></span>
										<span style="height: 88%"></span>
										<span style="height: 58%"></span>
									</div>
									<div class="report-list">
										<span></span>
										<span></span>
										<span></span>
									</div>
								</div>
							)}
						</div>
					</article>
				))}
				<a class="text-cta centered" href="#how-it-works">Learn more</a>
			</div>
		</section>

		<section class="benefits" id="benefits">
			<div class="section-shell">
				<div class="section-heading wide">
					<p class="eyebrow">Benefits</p>
					<h2>Consistent feedback loops make annual reviews easier, or less necessary.</h2>
				</div>
				<div class="benefit-grid">
					{benefits.map(([title, body]) => (
						<article>
							<span class="benefit-icon" aria-hidden="true"></span>
							<h3>{title}</h3>
							<p>{body}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="stories" id="resources">
			<div class="section-shell">
				<div class="section-heading centered-heading">
					<p class="eyebrow">Customers</p>
					<h2>Meet the teams using shresorigins to improve retention, engagement, and productivity.</h2>
					<a class="text-cta" href="#demo">See all stories</a>
				</div>
				<div class="story-grid">
					{stories.map((story) => (
						<article class={`story-card ${story.tone}`}>
							<p>"{story.quote}"</p>
							<div>
								<span class="avatar avatar-b"></span>
								<strong>{story.name}</strong>
								<small>{story.title} at {story.company}</small>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="how-it-works" id="how-it-works">
			<div class="section-shell">
				<p class="eyebrow">How it works</p>
				<h2>Discover the power of shresorigins.</h2>
				<div class="work-grid">
					{workCards.map(([title, body]) => (
						<a href="#demo">
							<h3>{title}</h3>
							<p>{body}</p>
							<span>Know more</span>
						</a>
					))}
				</div>
			</div>
		</section>

		<section class="final-cta" id="demo">
			<div class="section-shell">
				<p class="eyebrow">Get started</p>
				<h2>Go beyond annual reviews. Get shresorigins.</h2>
				<a class="pill-button pill-outline-light" href="mailto:hello@shresorigins.com?subject=shresorigins%20demo">Book a demo</a>
			</div>
		</section>
	</main>

	<footer class="footer" id="footer">
		<div class="section-shell footer-grid">
			<div class="footer-brand">
				<a class="logo" href="#main" aria-label="shresorigins home">
					<span class="logo-mark" aria-hidden="true"><span></span></span>
					<span>shresorigins</span>
				</a>
				<p>Go beyond annual reviews. Get shresorigins.</p>
			</div>
			<div class="footer-links">
				{footerGroups.map(([group, links]) => (
					<div>
						<h3>{group}</h3>
						<ul>
							{links.map((link) => <li><a href="#main">{link}</a></li>)}
						</ul>
					</div>
				))}
			</div>
			<div class="footer-bottom">
				<p>&copy; {new Date().getFullYear()} shresorigins. All rights reserved.</p>
				<div>
					<a href="#main">Terms</a>
					<a href="#main">Security</a>
					<a href="#main">Privacy policy</a>
					<a href="#main">Cookie policy</a>
				</div>
			</div>
		</div>
	</footer>

	<script is:inline>
		const navToggle = document.querySelector('[data-nav-toggle]');
		const header = document.querySelector('[data-site-header]');
		const navMenu = document.querySelector('[data-nav-menu]');
		const setOpen = (open) => {
			header?.classList.toggle('is-open', open);
			navToggle?.setAttribute('aria-expanded', String(open));
		};
		navToggle?.addEventListener('click', () => setOpen(!header?.classList.contains('is-open')));
		navMenu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setOpen(false)));
		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') setOpen(false);
		});
	</script>

	<script type="application/ld+json" set:html={JSON.stringify(schema)} />

	<style>
		:global(body) {
			background: #f5f2eb;
		}

		:global(html) {
			scroll-behavior: smooth;
		}

		.site-nav,
		#main,
		.footer {
			--navy: #08213a;
			--teal: #073d41;
			--teal-2: #0f6261;
			--cream: #f5f2eb;
			--paper: #fffdf7;
			--ink: #0c1c2c;
			--muted: #526270;
			--line: rgba(8, 33, 58, 0.14);
			--mint: #a7dfd0;
			--coral: #ff8a65;
			--lavender: #b6a6f3;
			--yellow: #f4c84a;
			--blue: #7bb6c8;
			color: var(--ink);
			font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		}

		.site-nav *,
		#main *,
		.footer * {
			box-sizing: border-box;
		}

		.site-nav a,
		#main a,
		.footer a {
			color: inherit;
			text-decoration: none;
		}

		.section-shell,
		.nav-shell,
		.hero-shell {
			width: min(1180px, calc(100% - 32px));
			margin: 0 auto;
		}

		.site-nav {
			position: sticky;
			top: 0;
			z-index: 50;
			background: #062b31;
			color: #ffffff;
			border-bottom: 1px solid rgba(255, 255, 255, 0.12);
		}

		.nav-shell {
			display: grid;
			grid-template-columns: auto 1fr auto;
			align-items: center;
			min-height: 72px;
			gap: 28px;
		}

		.logo {
			display: inline-flex;
			align-items: center;
			gap: 10px;
			font-size: 23px;
			font-weight: 800;
			letter-spacing: 0;
		}

		.logo-mark {
			position: relative;
			display: inline-grid;
			width: 31px;
			height: 31px;
			overflow: hidden;
			border-radius: 50%;
			background: conic-gradient(from 0deg, var(--coral) 0 25%, var(--yellow) 25% 50%, var(--teal-2) 50% 100%);
		}

		.logo-mark span {
			position: absolute;
			right: 0;
			bottom: 0;
			width: 50%;
			height: 50%;
			background: #062b31;
		}

		.nav-links,
		.nav-actions {
			display: flex;
			align-items: center;
			gap: 7px;
		}

		.nav-links {
			justify-content: center;
		}

		.nav-links a,
		.nav-actions a:not(.pill-button) {
			border-radius: 999px;
			color: rgba(255, 255, 255, 0.82);
			font-size: 13px;
			font-weight: 650;
			padding: 9px 11px;
			transition: background-color 180ms ease, color 180ms ease;
		}

		.nav-links a:hover,
		.nav-actions a:not(.pill-button):hover {
			background: rgba(255, 255, 255, 0.1);
			color: #ffffff;
		}

		.pill-button {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-height: 46px;
			border-radius: 999px;
			border: 1px solid transparent;
			font-size: 14px;
			font-weight: 800;
			padding: 0 18px;
			transition: transform 180ms ease, background-color 180ms ease, color 180ms ease, border-color 180ms ease;
		}

		.pill-button:hover {
			transform: translateY(-1px);
		}

		.pill-outline {
			border-color: rgba(255, 255, 255, 0.82);
			color: #ffffff;
		}

		.pill-outline:hover,
		.pill-outline-light:hover {
			background: #ffffff;
			color: var(--teal);
		}

		.pill-light {
			background: #fffdf7;
			color: var(--teal);
			box-shadow: 0 18px 42px rgba(0, 0, 0, 0.22);
		}

		.pill-dark {
			background: var(--teal);
			color: #ffffff;
		}

		.pill-outline-light {
			border-color: rgba(255, 255, 255, 0.86);
			color: #ffffff;
		}

		.menu-button {
			display: none;
			width: 44px;
			height: 44px;
			align-items: center;
			justify-content: center;
			flex-direction: column;
			gap: 5px;
			border: 1px solid rgba(255, 255, 255, 0.28);
			border-radius: 999px;
			background: transparent;
			color: #ffffff;
			cursor: pointer;
		}

		.menu-button span:not(.sr-only) {
			display: block;
			width: 18px;
			height: 2px;
			border-radius: 999px;
			background: currentColor;
			transition: transform 180ms ease, opacity 180ms ease;
		}

		.sr-only {
			position: absolute;
			width: 1px;
			height: 1px;
			overflow: hidden;
			clip: rect(0, 0, 0, 0);
			white-space: nowrap;
		}

		.site-nav.is-open .menu-button span:nth-child(2) {
			transform: translateY(7px) rotate(45deg);
		}

		.site-nav.is-open .menu-button span:nth-child(3) {
			opacity: 0;
		}

		.site-nav.is-open .menu-button span:nth-child(4) {
			transform: translateY(-7px) rotate(-45deg);
		}

		.hero {
			position: relative;
			overflow: hidden;
			background: var(--teal);
			color: #ffffff;
			min-height: 850px;
			padding: 92px 0 70px;
		}

		.hero::before {
			position: absolute;
			inset: 0;
			background:
				linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
				linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
			background-size: 25% 100%, 25% 100%;
			content: "";
			pointer-events: none;
		}

		.hero-shell {
			position: relative;
			z-index: 2;
			display: grid;
			justify-items: center;
			text-align: center;
		}

		.hero-copy {
			max-width: 720px;
		}

		h1,
		h2 {
			margin: 0;
			font-family: Georgia, "Times New Roman", serif;
			font-weight: 500;
			letter-spacing: 0;
		}

		.hero h1 {
			font-size: clamp(48px, 8vw, 86px);
			line-height: 0.96;
			text-wrap: balance;
		}

		.hero-copy p {
			max-width: 620px;
			margin: 22px auto 0;
			color: rgba(255, 255, 255, 0.78);
			font-size: 17px;
			line-height: 1.65;
		}

		.hero-copy .pill-button {
			margin-top: 26px;
		}

		.hero-art span {
			position: absolute;
			display: block;
			pointer-events: none;
		}

		.paper {
			opacity: 0.95;
			transform: rotate(-9deg);
		}

		.paper-lavender {
			top: 0;
			left: 8%;
			width: 160px;
			height: 170px;
			border-radius: 0 0 80px 0;
			background: var(--lavender);
		}

		.paper-mint {
			top: 112px;
			left: 23%;
			width: 170px;
			height: 118px;
			background: var(--mint);
		}

		.paper-coral {
			right: -55px;
			top: 220px;
			width: 210px;
			height: 210px;
			border-radius: 55% 45% 50% 45%;
			background: var(--coral);
		}

		.paper-blue {
			right: 12%;
			top: 78px;
			width: 110px;
			height: 88px;
			background: var(--blue);
			transform: rotate(12deg);
		}

		.dash {
			border-top: 2px dashed rgba(255, 255, 255, 0.55);
		}

		.dash-one {
			top: 165px;
			left: 12%;
			width: 285px;
			transform: rotate(12deg);
		}

		.dash-two {
			top: 140px;
			right: 21%;
			width: 210px;
