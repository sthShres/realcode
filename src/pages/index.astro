---
import BaseLayout from '../layouts/BaseLayout.astro';

const companyPillars = [
	{
		title: "Practical Digital Utilities",
		body: "We build browser-based products that solve everyday measurement and workflow problems without requiring accounts, installs, or complex setup.",
	},
	{
		title: "Clarity Before Complexity",
		body: "Each product is designed around clean controls, readable feedback, and decisions that help people trust what they are using.",
	},
	{
		title: "Reliable Product Craft",
		body: "Shrestha Origins focuses on lightweight tools with careful calibration, durable interfaces, and useful documentation around real-world accuracy.",
	},
];

const productHighlights = [
	["Current Product", "Scale"],
	["Measurement Units", "CM, MM, Inches"],
	["Calibration", "Auto, Diagonal, Card"],
];

const schema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	name: "Shrestha Origins",
	url: "https://realcode.com/",
	description: "Shrestha Origins builds polished browser-based utility products, including Scale for calibrated screen measurement.",
	brand: {
		"@type": "Brand",
		name: "Shrestha Origins",
	},
	makesOffer: {
		"@type": "Offer",
		itemOffered: {
			"@type": "WebApplication",
			name: "Scale",
			applicationCategory: "UtilitiesApplication",
		},
	},
};
---

<BaseLayout
	title="Professional Digital Utility Products"
	description="Shrestha Origins is a digital product company building professional browser utilities, including Scale for calibrated on-screen measurement."
	ogImageAlt="Shrestha Origins Scale product preview"
>
	<main id="main">
		<section class="landing-hero">
			<div class="landing-hero-visual" aria-hidden="true">
				<div class="hero-ruler hero-ruler-top"></div>
				<div class="hero-ruler hero-ruler-side"></div>
				<div class="hero-measure-card">
					<span class="hero-measure-label">Scale</span>
					<strong>85.60 mm</strong>
					<small>calibrated browser measurement</small>
				</div>
			</div>
			<div class="landing-hero-content mx-auto max-w-7xl px-spacing-md md:px-spacing-lg">
				<p class="font-mono text-xs uppercase text-white/70">Shrestha Origins</p>
				<h1 class="mt-spacing-sm max-w-4xl text-balance text-5xl font-semibold leading-tight tracking-normal text-white md:text-7xl">
					Professional browser tools for precise everyday work.
				</h1>
				<p class="mt-spacing-lg max-w-2xl text-lg leading-8 text-white/78">
					Shrestha Origins creates focused digital utility products with clean interfaces, dependable calibration, and documentation that helps people use the web as a practical workspace.
				</p>
				<div class="mt-spacing-xl flex flex-wrap gap-spacing-sm">
					<a href="/product/" class="btn-hero-primary focus-visible-ring">View Scale Product</a>
					<a href="/features/" class="btn-hero-secondary focus-visible-ring">Explore Features</a>
				</div>
			</div>
		</section>

		<section class="bg-canvas px-spacing-md py-spacing-4xl md:px-spacing-lg">
			<div class="mx-auto grid max-w-7xl gap-spacing-xl lg:grid-cols-[0.9fr_1.1fr]">
				<div>
					<p class="mb-spacing-sm font-mono text-xs text-mute">company</p>
					<h2 class="text-balance text-4xl font-semibold tracking-normal">Built around useful products, not noise.</h2>
				</div>
				<div class="space-y-spacing-md text-lg leading-8 text-body">
					<p>
						Shrestha Origins is a product-focused company developing modern browser utilities for people who need quick, understandable tools. Our work starts with practical needs, then adds the polish, structure, and accuracy guidance expected from professional software.
					</p>
					<p>
						The company’s first product, Scale, turns a screen into a calibrated measuring surface for centimeters, millimeters, and inches. It reflects the way we build: direct workflows, clear controls, and dependable results that respect the user’s time.
					</p>
				</div>
			</div>
		</section>

		<section class="bg-canvas-soft px-spacing-md py-spacing-4xl md:px-spacing-lg">
			<div class="mx-auto max-w-7xl">
				<div class="mb-spacing-xl max-w-2xl">
					<p class="mb-spacing-sm font-mono text-xs text-mute">principles</p>
					<h2 class="text-balance text-4xl font-semibold tracking-normal">A disciplined approach to small, high-value tools.</h2>
				</div>
				<div class="grid gap-spacing-md md:grid-cols-3">
					{companyPillars.map((pillar, index) => (
						<article class="card-marketing">
							<span class="font-mono text-xs text-mute">{String(index + 1).padStart(2, "0")}</span>
							<h3 class="mt-spacing-md text-xl font-semibold tracking-normal">{pillar.title}</h3>
							<p class="mt-spacing-xs text-body">{pillar.body}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="bg-canvas px-spacing-md py-spacing-4xl md:px-spacing-lg">
			<div class="product-feature mx-auto max-w-7xl">
				<div class="product-feature-copy">
					<p class="mb-spacing-sm font-mono text-xs text-mute">product</p>
					<h2 class="text-balance text-4xl font-semibold tracking-normal">Scale is the first Shrestha Origins utility.</h2>
					<p class="mt-spacing-md text-lg leading-8 text-body">
						Use Scale to measure actual size on screen, calibrate with a known reference, and switch between edge placements for objects that are easier to align from different sides.
					</p>
					<div class="mt-spacing-lg grid gap-spacing-sm sm:grid-cols-3">
						{productHighlights.map(([label, value]) => (
							<div class="stat-tile">
								<span>{label}</span>
								<strong>{value}</strong>
							</div>
						))}
					</div>
					<a href="/product/" class="btn-primary focus-visible-ring mt-spacing-lg">Open Product Page</a>
				</div>
				<a href="/product/" class="product-preview focus-visible-ring" aria-label="Open Scale product page">
					<img src="/og-online-ruler.svg" alt="Scale product interface preview" loading="lazy" />
				</a>
			</div>
		</section>
	</main>

	<script type="application/ld+json" set:html={JSON.stringify(schema)} />
</BaseLayout>
