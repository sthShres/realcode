---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
	["Is Shrestha Origins Scale free?", "Yes. The online ruler runs in the browser and does not require an account."],
	["Does calibration sync between devices?", "No. Calibration is saved locally because each device and display can need a different scale."],
	["Can I measure in inches?", "Yes. Use the cm/in segmented control on the Scale product page."],
	["Why are bottom and side rulers useful?", "They let you align objects against the closest screen edge instead of rotating the device or moving the object across the display."],
];
---

<BaseLayout
	title="Online Ruler FAQ"
	description="Answers to common questions about Shrestha Origins Scale, calibration, units, and browser measurement accuracy."
	canonicalPath="/faq/"
>
	<main id="main">
		<section class="bg-canvas px-spacing-md py-spacing-5xl md:px-spacing-lg">
			<div class="mx-auto max-w-4xl">
				<p class="mb-spacing-sm font-mono text-xs text-mute">faq</p>
				<h1 class="text-balance text-5xl font-semibold leading-tight tracking-normal">Online Ruler Questions.</h1>
				<div class="mt-spacing-xl divide-y divide-hairline rounded-lg border border-hairline bg-canvas">
					{faqs.map(([question, answer]) => (
						<details class="p-spacing-lg">
							<summary class="cursor-pointer list-none text-lg font-medium focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-link">
								{question}
							</summary>
							<p class="mt-spacing-sm text-body">{answer}</p>
						</details>
					))}
				</div>
			</div>
		</section>
	</main>
</BaseLayout>
