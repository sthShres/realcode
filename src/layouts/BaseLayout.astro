---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	canonicalPath?: string;
	keywords?: string;
	ogImage?: string;
	ogImageAlt?: string;
}

const {
	title,
	description = "Use Shrestha Origins Scale to measure in centimeters, millimeters, and inches with auto-detect, screen diagonal, and credit card calibration.",
	canonicalPath = "/",
	keywords,
	ogImage = "/og-online-ruler.svg",
	ogImageAlt = "Shrestha Origins Scale measuring interface",
} = Astro.props;
const canonical = new URL(canonicalPath, Astro.site ?? "https://realcode.com").toString();
const absoluteOgImage = new URL(ogImage, Astro.site ?? "https://realcode.com").toString();
const pageTitle = `${title} | Shrestha Origins`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		{keywords && <meta name="keywords" content={keywords} />}
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<link rel="canonical" href={canonical} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:site_name" content="Shrestha Origins" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={absoluteOgImage} />
		<meta property="og:image:secure_url" content={absoluteOgImage} />
		<meta property="og:image:type" content="image/svg+xml" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={ogImageAlt} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={absoluteOgImage} />
		<meta name="twitter:image:alt" content={ogImageAlt} />
		<meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
		<link rel="preconnect" href="https://rsms.me/" />
		<link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
		<script is:inline>
			const theme = localStorage.getItem('realcode-theme');
			const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			if (theme === 'dark' || (!theme && prefersDark)) {
				document.documentElement.classList.add('dark');
			}
		</script>
	</head>
	<body class="bg-canvas-soft text-ink font-sans selection:bg-primary selection:text-on-primary">
		<a href="#main" class="skip-link">Skip to content</a>
		<nav class="sticky top-0 z-50 border-b border-hairline bg-canvas/90 px-spacing-sm backdrop-blur-md md:px-spacing-lg">
			<div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-spacing-md">
				<a href="/" class="focus-visible-ring flex min-w-0 items-center gap-spacing-xs rounded-sm" aria-label="Shrestha Origins home">
					<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-sm bg-primary text-lg font-semibold text-on-primary">s</span>
					<span class="brand-wordmark truncate text-lg font-semibold tracking-normal">Shrestha Origins</span>
				</a>
				<div class="flex items-center gap-spacing-xs md:gap-spacing-md">
					<a href="/product/" class="nav-link">Product</a>
					<a href="/calibration/" class="nav-link nav-link-calibrate">Calibrate</a>
					<a href="/features/" class="nav-link hidden sm:inline-flex">Features</a>
					<a href="/accuracy-guide/" class="btn-primary-sm focus-visible-ring"><span class="hidden sm:inline">Accuracy Guide</span><span class="sm:hidden">Guide</span></a>
					<button class="theme-toggle" type="button" aria-label="Toggle dark mode" data-theme-toggle>
						<svg class="theme-toggle-sun" aria-hidden="true" viewBox="0 0 24 24"><path d="M12 4V2M12 22v-2M4 12H2M22 12h-2M5.64 5.64 4.22 4.22M19.78 19.78l-1.42-1.42M18.36 5.64l1.42-1.42M4.22 19.78l1.42-1.42" /><circle cx="12" cy="12" r="4" /></svg>
						<svg class="theme-toggle-moon" aria-hidden="true" viewBox="0 0 24 24"><path d="M20 14.4A7.6 7.6 0 0 1 9.6 4a8 8 0 1 0 10.4 10.4Z" /></svg>
					</button>
				</div>
			</div>
		</nav>

		<slot />

		<footer class="border-t border-hairline bg-canvas px-spacing-lg py-spacing-4xl">
			<div class="mx-auto grid max-w-7xl grid-cols-1 gap-spacing-xl md:grid-cols-4">
				<div class="col-span-1 md:col-span-2">
					<div class="mb-spacing-md flex items-center gap-spacing-xs">
						<div class="flex h-6 w-6 items-center justify-center rounded-xs bg-primary text-sm font-semibold text-on-primary">s</div>
						<span class="text-sm font-semibold tracking-normal">Shrestha Origins</span>
					</div>
					<p class="max-w-xs text-sm text-body">
						Professional browser-based utility products from Shrestha Origins with clear calibration, persistent settings, and real-size tools for everyday work.
					</p>
				</div>
				<div>
					<h4 class="mb-spacing-md font-mono text-xs text-mute">Product</h4>
					<ul class="space-y-spacing-xs text-sm text-body">
						<li><a href="/product/" class="focus-visible-ring hover:text-ink">Scale</a></li>
						<li><a href="/calibration/" class="focus-visible-ring hover:text-ink">Calibration</a></li>
						<li><a href="/features/" class="focus-visible-ring hover:text-ink">Features</a></li>
					</ul>
				</div>
				<div>
					<h4 class="mb-spacing-md font-mono text-xs text-mute">Resources</h4>
					<ul class="space-y-spacing-xs text-sm text-body">
						<li><a href="/accuracy-guide/" class="focus-visible-ring hover:text-ink">Accuracy Guide</a></li>
						<li><a href="/faq/" class="focus-visible-ring hover:text-ink">FAQ</a></li>
					</ul>
				</div>
			</div>
			<div class="mx-auto mt-spacing-xl flex max-w-7xl flex-col items-center justify-between gap-spacing-md border-t border-hairline pt-spacing-xl font-mono text-xs text-mute md:flex-row">
				<p>&copy; {new Date().getFullYear()} Shrestha Origins. All rights reserved.</p>
				<span>Built for calibrated browser measurement</span>
			</div>
		</footer>
		<script>
			const toggle = document.querySelector('[data-theme-toggle]');
			const syncLabel = () => {
				toggle?.setAttribute('aria-label', document.documentElement.classList.contains('dark') ? 'Switch To Light Mode' : 'Switch To Dark Mode');
			};
			syncLabel();
			toggle?.addEventListener('click', () => {
				const dark = document.documentElement.classList.toggle('dark');
				localStorage.setItem('realcode-theme', dark ? 'dark' : 'light');
				syncLabel();
			});
		</script>
	</body>
</html>
